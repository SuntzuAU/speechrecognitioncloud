---
import site from '../site.config.json';
const { title, description, canonicalUrl } = Astro.props;
const pageTitle = title ? `${title} | ${site.siteName}` : site.seoTitle;
const pageDescription = description || site.seoDescription;
const c = site.colours;
const R2 = import.meta.env.PUBLIC_R2_BASE || '';
---
<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
  <link rel="icon" type="image/jpeg" href="/logo.jpg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;0,9..40,800;1,9..40,400&display=swap" rel="stylesheet" />
  <style is:inline>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --brand: #4338CA;
      --brand-light: #818CF8;
      --brand-lightest: #EEF2FF;
      --cta: #EA580C;
      --cta-hover: #C2410C;
      --text: #0F172A;
      --muted: #64748B;
      --bg: #FFFFFF;
      --neutral: #F8FAFC;
      --dark: #0F172A;
      --dark-text: #E2E8F0;
      --dark-muted: #94A3B8;
      --dark-accent: #818CF8;
      --border: #E2E8F0;
      --font: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
      --max-width: 1140px;
    }
    html { scroll-behavior: smooth; }
    body { font-family: var(--font); color: var(--text); background: var(--bg); line-height: 1.6; -webkit-font-smoothing: antialiased; }
    img { max-width: 100%; height: auto; display: block; }
    a { color: inherit; text-decoration: none; }
    .container { max-width: var(--max-width); margin: 0 auto; padding: 0 24px; }
    .btn-primary { display: inline-flex; align-items: center; gap: 8px; background: var(--cta); color: #fff; padding: 14px 32px; border-radius: 10px; font-size: 16px; font-weight: 600; font-family: var(--font); transition: background 0.2s, transform 0.1s; border: none; cursor: pointer; }
    .btn-primary:hover { background: var(--cta-hover); transform: translateY(-1px); }
    .btn-secondary { display: inline-flex; align-items: center; gap: 8px; background: transparent; color: var(--text); padding: 14px 32px; border-radius: 10px; font-size: 16px; font-weight: 600; font-family: var(--font); border: 2px solid var(--text); transition: background 0.2s, color 0.2s, transform 0.1s; cursor: pointer; }
    .btn-secondary:hover { background: var(--text); color: #fff; transform: translateY(-1px); }
    .section-pad { padding: 56px 0; }
    .section-neutral { background: var(--neutral); }
    .section-dark { background: var(--dark); color: var(--dark-text); }
    .section-dark .muted { color: var(--dark-muted); }
    .text-center { text-align: center; }
    h1, h2, h3, h4 { line-height: 1.2; letter-spacing: -0.02em; }
    h2 { font-size: clamp(24px, 3.5vw, 36px); font-weight: 700; }
    .accent { color: var(--brand); }
    .muted { color: var(--muted); }
    @media (max-width: 768px) { .section-pad { padding: 36px 0; } .container { padding: 0 16px; } }
  </style>
  {site.googleAnalyticsId && (
    <script is:inline define:vars={{ gaId: site.googleAnalyticsId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', gaId);
    </script>
  )}
  {site.googleAnalyticsId && (
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${site.googleAnalyticsId}`}></script>
  )}
</head>
<body>
  <header class="site-header">
    <div class="container header-inner">
      <a href="/" class="logo-link"><img src="/logo.jpg" alt={site.siteName} class="logo-img" loading="eager" /></a>
      <nav class="nav-desktop">
        {site.nav.links.map(link => (
          link.dropdown ? (
            <div class="nav-dropdown-wrap">
              <button class="nav-link nav-dropdown-trigger" aria-expanded="false">{link.label}<svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
              <div class="nav-dropdown-menu">{site.nav.useCases.map(uc => (<a href={uc.href} class="nav-dropdown-item">{uc.label}</a>))}</div>
            </div>
          ) : (<a href={link.href} class="nav-link">{link.label}</a>)
        ))}
      </nav>
      <a href={site.nav.ctaUrl} class="btn-primary header-cta">{site.nav.ctaText}</a>
      <button class="mobile-toggle" aria-label="Open menu" aria-expanded="false"><span></span><span></span><span></span></button>
    </div>
    <div class="mobile-nav">
      {site.nav.links.map(link => (
        link.dropdown ? (
          <details class="mobile-dropdown"><summary class="nav-link">{link.label}</summary><div class="mobile-dropdown-items">{site.nav.useCases.map(uc => (<a href={uc.href} class="nav-link">{uc.label}</a>))}</div></details>
        ) : (<a href={link.href} class="nav-link">{link.label}</a>)
      ))}
      <a href={site.nav.ctaUrl} class="btn-primary" style="margin-top:12px;text-align:center;justify-content:center">{site.nav.ctaText}</a>
    </div>
  </header>
  <slot />
  <footer class="section-dark" style="padding:48px 0 28px">
    <div class="container">
      <div class="footer-grid">
        <div class="footer-brand">
          <img src="/logo.jpg" alt={site.siteName} width="180" loading="lazy" decoding="async" style="filter:brightness(0) invert(1);opacity:0.9" />
          <p class="muted" style="margin-top:12px;font-size:14px;max-width:280px">{site.footer.tagline}</p>
        </div>
        {site.footer.columns.map(col => (<div class="footer-col"><h4 style="font-size:14px;font-weight:600;margin-bottom:12px;letter-spacing:0">{col.heading}</h4>{col.links.map(link => (<a href={link.href} style="display:block;font-size:14px;color:var(--dark-muted);margin-bottom:8px;transition:color 0.2s">{link.label}</a>))}</div>))}
      </div>
      <div style="border-top:1px solid rgba(255,255,255,0.1);margin-top:32px;padding-top:20px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px">
        <p style="font-size:13px;color:var(--dark-muted)">&copy; {site.footer.copyright}</p>
        <div style="display:flex;gap:16px">{site.footer.social.map(s => (<a href={s.url} target="_blank" rel="noopener noreferrer" style="font-size:13px;color:var(--dark-muted)">{s.platform}</a>))}</div>
      </div>
    </div>
  </footer>
  <style is:inline>
    .site-header { position: sticky; top: 0; z-index: 100; background: rgba(255,255,255,0.92); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); }
    .header-inner { display: flex; align-items: center; height: 72px; gap: 32px; }
    .logo-link { display: flex; align-items: center; }
    .logo-img { height: 46px; width: auto; }
    .nav-desktop { display: flex; align-items: center; gap: 4px; flex: 1; }
    .nav-link { font-size: 15px; font-weight: 500; color: var(--text); padding: 8px 14px; border-radius: 8px; transition: background 0.15s; background: none; border: none; cursor: pointer; font-family: var(--font); display: inline-flex; align-items: center; gap: 4px; }
    .nav-link:hover { background: var(--neutral); }
    .header-cta { padding: 10px 24px; font-size: 14px; white-space: nowrap; border-radius: 8px; }
    .mobile-toggle { display: none; background: none; border: none; cursor: pointer; padding: 8px; flex-direction: column; gap: 5px; }
    .mobile-toggle span { display: block; width: 22px; height: 2px; background: var(--text); border-radius: 2px; transition: transform 0.2s; }
    .mobile-nav { display: none; padding: 16px 24px; border-top: 1px solid var(--border); background: #fff; }
    .mobile-nav .nav-link { display: block; padding: 10px 0; }
    .mobile-nav.open { display: block; }
    .mobile-dropdown-items { padding-left: 16px; }
    .mobile-dropdown-items .nav-link { font-size: 14px; color: var(--muted); }
    .nav-dropdown-wrap { position: relative; }
    .nav-dropdown-menu { display: none; position: absolute; top: 100%; left: 0; background: #fff; border: 1px solid var(--border); border-radius: 12px; padding: 8px; min-width: 240px; box-shadow: 0 12px 32px rgba(0,0,0,0.08); z-index: 50; }
    .nav-dropdown-wrap:hover .nav-dropdown-menu { display: block; }
    .nav-dropdown-item { display: block; padding: 10px 14px; font-size: 14px; font-weight: 500; border-radius: 8px; transition: background 0.15s; }
    .nav-dropdown-item:hover { background: var(--neutral); }
    .footer-grid { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr 1fr; gap: 40px; }
    @media (max-width: 768px) { .nav-desktop, .header-cta { display: none; } .mobile-toggle { display: flex; } .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; } .footer-brand { grid-column: 1 / -1; } }
    @media (max-width: 480px) { .footer-grid { grid-template-columns: 1fr; } }
  </style>
  <script is:inline>
    document.querySelector('.mobile-toggle')?.addEventListener('click', function() {
      var nav = document.querySelector('.mobile-nav');
      var isOpen = nav.classList.toggle('open');
      this.setAttribute('aria-expanded', isOpen);
    });
  </script>
</body>
</html>
