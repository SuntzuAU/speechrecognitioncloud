---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../site.config.json';
---
<BaseLayout title="Business and professionals" description="Emails, reports, and documentation at the speed of speech. Speech Recognition Cloud for business professionals.">
  <section class="section-pad">
    <div class="container usecase-hero">
      <div>
        <p class="eyebrow">BUSINESS</p>
        <h1 style="font-size:clamp(28px,4vw,42px);font-weight:800;margin-bottom:16px">Emails, reports, and documentation at the speed of speech</h1>
        <p class="muted" style="font-size:16px;line-height:1.7;margin-bottom:24px;max-width:500px">Stop typing and start dictating. Speech Recognition Cloud lets you produce emails, reports, proposals, and documentation faster than typing, with automatic punctuation and grammar.</p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:12px"><a href={site.download.url} class="btn-primary">Download free</a><a href="/contact" class="btn-secondary">Contact us</a></div>
        <p class="muted" style="font-size:13px">No credit card required. Windows 10/11.</p>
      </div>
    </div>
  </section>
  <section class="section-pad section-neutral">
    <div class="container" style="max-width:800px">
      <h2 class="text-center" style="margin-bottom:40px">Built for business productivity</h2>
      <div class="benefit-grid">
        <div class="benefit"><h3>Works in Outlook, Word, Teams, and Chrome</h3><p class="muted">Dictate directly into your daily tools. Email, documents, web forms, CRMs, and project management tools. Anywhere you can type.</p></div>
        <div class="benefit"><h3>3x faster than typing</h3><p class="muted">Full paragraphs appear with punctuation and grammar. Reduce the time you spend on written communication.</p></div>
        <div class="benefit"><h3>AI modes for professional writing</h3><p class="muted">Rewrite, formalise, or summarise your dictated text. Polish emails and reports without manual editing. Available on Professional plan.</p></div>
        <div class="benefit"><h3>Templates and text replacements</h3><p class="muted">Insert standard responses, email templates, and frequently used paragraphs by voice command.</p></div>
        <div class="benefit"><h3>Custom vocabulary</h3><p class="muted">Add industry terms, client names, product names, and abbreviations for better accuracy.</p></div>
        <div class="benefit"><h3>Affordable for individuals and teams</h3><p class="muted">Start free. Personal plan at $79/year for unlimited dictation. Professional at $159/year for AI modes and Ultra Accuracy.</p></div>
      </div>
    </div>
  </section>
  <section class="section-pad">
    <div class="container text-center" style="max-width:600px">
      <h2 style="margin-bottom:12px">Try it free today</h2>
      <p class="muted" style="margin-bottom:24px">20 minutes per month on the free plan. No credit card required.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap"><a href="/pricing" class="btn-secondary">View pricing</a><a href={site.download.url} class="btn-primary">Download free</a></div>
    </div>
  </section>
  <style is:inline>
    .eyebrow{font-size:12px;font-weight:600;color:var(--brand);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:12px}
    .usecase-hero{max-width:700px}
    .benefit-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
    .benefit{padding:24px;border:1px solid var(--border);border-radius:14px;background:#fff}
    .benefit h3{font-size:16px;font-weight:600;margin-bottom:8px}
    .benefit .muted{font-size:14px;line-height:1.7}
    @media(max-width:768px){.benefit-grid{grid-template-columns:1fr}}
  </style>
</BaseLayout>
