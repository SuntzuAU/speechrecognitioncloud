  "url": "https://www.voicerecognition.com.au",
  "sameAs": [
    "https://www.linkedin.com/in/rbewsell/"
  ],
  "worksFor": {
    "@type": "Organization",
    "name": "Voice Recognition Australia",
    "url": "https://www.voicerecognition.com.au"
