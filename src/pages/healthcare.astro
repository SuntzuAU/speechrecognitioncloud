  "@type": "MedicalWebPage",
  "@id": pageUrl + "#webpage",
  "url": pageUrl,
  "name": "Verbatim Voice Dictation for Healthcare Teams: A Practical Guide",
  "description": "Practical guide to verbatim voice dictation for healthcare teams — doctors, nurses, allied health, pharmacy, and clinical administrators. Speech Recognition Cloud Medical: no AI generation, no data stored. Written by Russell Bewsell, Voice Recognition Australia.",
  "inLanguage": "en",
  "isPartOf": { "@type": "WebSite", "name": site.siteName, "url": site.siteUrl },
  "datePublished": "2026-05-16",
  "dateModified": lastReviewed,
  "lastReviewed": lastReviewed,
  "about": [
    { "@type": "Thing", "name": "Healthcare dictation" },
    { "@type": "Thing", "name": "Verbatim voice dictation" },
    { "@type": "Thing", "name": "Allied health documentation" },
    { "@type": "Thing", "name": "Nursing documentation" },
    { "@type": "Thing", "name": "Pharmacy documentation" },
    { "@type": "Thing", "name": "NDIS reporting" }
