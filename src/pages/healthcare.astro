---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../site.config.json';
---
<BaseLayout title="Healthcare professionals" description="Medical dictation with specialised vocabulary. Speech Recognition Cloud works with any EMR at the cursor. No voice training required.">
  <section class="section-pad">
    <div class="container usecase-hero">
      <div>
        <p class="eyebrow">HEALTHCARE</p>
        <h1 style="font-size:clamp(28px,4vw,42px);font-weight:800;margin-bottom:16px">Medical dictation without the friction</h1>
        <p class="muted" style="font-size:16px;line-height:1.7;margin-bottom:24px;max-width:500px">Dictate clinical notes, referrals, and correspondence directly into your EMR or any Windows application. Specialised medical vocabulary. No voice training. No clunky dictation boxes.</p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:12px"><a href={site.download.url} class="btn-primary">Download free</a><a href="/contact" class="btn-secondary">Contact us</a></div>
        <p class="muted" style="font-size:13px">No credit card required. Windows 10/11.</p>
      </div>
    </div>
  </section>
  <section class="section-pad section-neutral">
    <div class="container" style="max-width:800px">
      <h2 class="text-center" style="margin-bottom:40px">Built for clinical workflows</h2>
      <div class="benefit-grid">
        <div class="benefit"><h3>Works with any EMR</h3><p class="muted">Dictate at the cursor in Best Practice, Medical Director, Genie, Zedmed, or any Windows-based clinical software. No special integration required.</p></div>
        <div class="benefit"><h3>Medical vocabulary</h3><p class="muted">Specialised medical vocabularies included on the Medical plan. Add your own terms, drug names, and abbreviations through custom vocabulary.</p></div>
        <div class="benefit"><h3>Ultra Accuracy Medical Mode</h3><p class="muted">Enhanced accuracy processing designed for clinical terminology. Available on the Medical plan.</p></div>
        <div class="benefit"><h3>Privacy controls</h3><p class="muted">Audio is processed and immediately discarded. Text is not stored on our servers. Your data is never used for AI model training. Restricted AI modes for additional privacy.</p></div>
        <div class="benefit"><h3>No voice training</h3><p class="muted">Install and start dictating immediately. No voice profiles, no calibration, no setup wizards. The cloud AI handles accuracy from day one.</p></div>
        <div class="benefit"><h3>Dedicated support</h3><p class="muted">Medical plan includes dedicated remote support and one-on-one training to help you get set up and productive.</p></div>
      </div>
    </div>
  </section>
  <section class="section-pad">
    <div class="container text-center" style="max-width:600px">
      <h2 style="margin-bottom:12px">Compare with your current system</h2>
      <p class="muted" style="margin-bottom:24px">Speech Recognition Cloud Medical starts at $439/year. No upgrade fees, no serial numbers, no compatibility headaches. See how it compares.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap"><a href="/pricing" class="btn-secondary">View pricing</a><a href={site.download.url} class="btn-primary">Download free</a></div>
    </div>
  </section>
  <style is:inline>
    .eyebrow{font-size:12px;font-weight:600;color:var(--brand);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:12px}
    .usecase-hero{max-width:700px}
    .benefit-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
    .benefit{padding:24px;border:1px solid var(--border);border-radius:14px;background:#fff}
    .benefit h3{font-size:16px;font-weight:600;margin-bottom:8px}
    .benefit .muted{font-size:14px;line-height:1.7}
    @media(max-width:768px){.benefit-grid{grid-template-columns:1fr}}
  </style>
</BaseLayout>
