---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import site from '../../site.config.json';

export async function getStaticPaths() {
  const posts = await getCollection('learn');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const R2_BASE = (import.meta.env.PUBLIC_R2_BASE ?? 'https://pub-c7a09e1ddb7c45e6a38fcdca1e4b6897.r2.dev').replace(/\/$/, '');
const imgSrc = (key) => key ? (/^https?:\/\//.test(key) ? key : `${R2_BASE}/${key}`) : '';
const typeLabels = { article: 'Article', guide: 'Guide', video: 'Video', tip: 'Tip' };
---
<BaseLayout title={post.data.title} description={post.data.description}>
  <article class="section-pad">
    <div class="container" style="max-width:760px">
      <div class="article-meta">
        <a href="/learn" class="back-link"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg> Back to Learn</a>
        <div style="display:flex;align-items:center;gap:10px">
          <span class={`learn-tag learn-tag--${post.data.type}`}>{typeLabels[post.data.type] || post.data.type}</span>
          <time datetime={post.data.date} class="muted">{new Date(post.data.date).toLocaleDateString('en-AU', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
        </div>
      </div>
      <h1 class="article-title">{post.data.title}</h1>

      {post.data.heroImage && (
        <div class="hero-img"><img src={imgSrc(post.data.heroImage)} alt={post.data.heroImageAlt ?? post.data.title} loading="eager" decoding="async" /></div>
      )}

      {post.data.youtubeId && (
        <div class="yt-facade" data-ytid={post.data.youtubeId} style="margin-bottom:32px">
          <img src={`https://i.ytimg.com/vi/${post.data.youtubeId}/maxresdefault.jpg`} alt={post.data.title} loading="eager" />
          <div class="yt-play"><svg viewBox="0 0 68 48" width="68" height="48"><path d="M66.5 7.7c-.8-2.9-2.5-5.4-5.4-6.2C55.8.1 34 0 34 0S12.2.1 6.9 1.6c-2.8.7-4.6 3.2-5.4 6.1C.1 13 0 24 0 24s0 11 1.5 16.3c.8 2.9 2.6 5.4 5.4 6.2C12.2 47.9 34 48 34 48s21.8-.1 27.1-1.6c2.8-.7 4.6-3.2 5.4-6.1C67.9 35 68 24 68 24s0-11-1.5-16.3z" fill="#FF0000"/><path d="M27 34V14l18 10-18 10z" fill="#FFF"/></svg></div>
        </div>
      )}

      <div class="article-body" id="article-prose"
        data-break1={post.data.breakImage1 ? imgSrc(post.data.breakImage1) : ''}
        data-break1-alt={post.data.breakImage1Alt ?? ''}
        data-break2={post.data.breakImage2 ? imgSrc(post.data.breakImage2) : ''}
        data-break2-alt={post.data.breakImage2Alt ?? ''}>
        <Content />
      </div>
    </div>
  </article>
  <section class="section-pad section-neutral">
    <div class="container text-center" style="max-width:600px">
      <h2 style="margin-bottom:12px">Try Speech Recognition Cloud</h2>
      <p class="muted" style="margin-bottom:24px">Free to download. No credit card required.</p>
      <a href={site.download.url} class="btn-primary">Download free</a>
    </div>
  </section>
  <style is:inline>
    .article-meta{display:flex;justify-content:space-between;align-items:center;margin-bottom:24px;flex-wrap:wrap;gap:12px}
    .back-link{display:inline-flex;align-items:center;gap:4px;font-size:14px;color:var(--brand);font-weight:600;text-decoration:none}
    .back-link:hover{text-decoration:underline}
    .learn-tag{font-size:11px;font-weight:600;padding:2px 8px;border-radius:6px;text-transform:uppercase;letter-spacing:0.04em}
    .learn-tag--article{color:var(--brand);background:var(--brand-lightest, #EEF2FF)}
    .learn-tag--guide{color:#059669;background:#ECFDF5}
    .learn-tag--video{color:#DC2626;background:#FEF2F2}
    .learn-tag--tip{color:#D97706;background:#FFFBEB}
    .hero-img{margin-bottom:32px;border-radius:16px;overflow:hidden;background:#F1F5F9}
    .hero-img img{width:100%;aspect-ratio:16/9;object-fit:cover;display:block}
    .img-break{margin:32px 0;border-radius:14px;overflow:hidden;background:#F1F5F9}
    .img-break img{width:100%;max-height:360px;object-fit:cover;display:block}
    .article-title{font-size:clamp(28px,4vw,40px);font-weight:800;margin-bottom:32px;line-height:1.2;letter-spacing:-0.02em}
    .article-body{font-size:16px;line-height:1.8;color:var(--text)}
    .article-body h2{font-size:24px;font-weight:700;margin-top:40px;margin-bottom:16px}
    .article-body h3{font-size:20px;font-weight:600;margin-top:32px;margin-bottom:12px}
    .article-body p{margin-bottom:20px;color:var(--muted)}
    .article-body a{color:var(--brand);font-weight:600}
    .article-body ul,.article-body ol{margin-bottom:20px;padding-left:24px;color:var(--muted)}
    .article-body li{margin-bottom:8px;line-height:1.7}
    .article-body blockquote{border-left:3px solid var(--brand);padding-left:20px;margin:24px 0;font-style:italic;color:var(--muted)}
    .article-body table{width:100%;border-collapse:collapse;margin:28px 0;font-size:15px;line-height:1.6;border:1px solid #E5E7EB}
    .article-body th,.article-body td{padding:11px 16px;border:1px solid #E5E7EB;text-align:left;vertical-align:top}
    .article-body thead th{background:var(--brand-lightest,#EEF2FF);color:var(--text);font-weight:700}
    .article-body tbody tr:nth-child(even){background:#F9FAFB}
    .article-body td strong,.article-body th strong{color:var(--text)}
    .yt-facade{position:relative;max-width:100%;cursor:pointer;border-radius:16px;overflow:hidden;background:#000;box-shadow:0 8px 32px rgba(0,0,0,0.12)}.yt-facade img{width:100%;aspect-ratio:16/9;object-fit:cover}.yt-facade .yt-play{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);opacity:0.9;transition:opacity 0.2s}.yt-facade:hover .yt-play{opacity:1}.yt-facade iframe{position:absolute;top:0;left:0;width:100%;height:100%;border:0}
  </style>
  <script is:inline>
    document.querySelectorAll('.yt-facade').forEach(function(el){el.addEventListener('click',function(){var id=el.dataset.ytid;var iframe=document.createElement('iframe');iframe.src='https://www.youtube-nocookie.com/embed/'+id+'?autoplay=1&rel=0&modestbranding=1';iframe.allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';iframe.allowFullscreen=true;el.innerHTML='';el.style.paddingBottom='56.25%';el.style.height='0';el.appendChild(iframe);});});
  </script>
  <script is:inline>
    (function () {
      var prose = document.getElementById('article-prose');
      if (!prose) return;
      var b1 = prose.getAttribute('data-break1'), b1a = prose.getAttribute('data-break1-alt') || '';
      var b2 = prose.getAttribute('data-break2'), b2a = prose.getAttribute('data-break2-alt') || '';
      if (!b1 && !b2) return;
      var h2s = prose.querySelectorAll('h2');
      if (!h2s.length) return;
      function mk(src, alt) {
        var w = document.createElement('div'); w.className = 'img-break';
        var i = document.createElement('img'); i.src = src; i.alt = alt; i.loading = 'lazy'; i.decoding = 'async';
        w.appendChild(i); return w;
      }
      if (b1 && h2s.length >= 2) prose.insertBefore(mk(b1, b1a), h2s[1]);
      if (b2) {
        var idx = Math.max(2, Math.floor(h2s.length * 2 / 3));
        if (h2s.length > idx) prose.insertBefore(mk(b2, b2a), h2s[idx]);
      }
    })();
  </script>
</BaseLayout>
