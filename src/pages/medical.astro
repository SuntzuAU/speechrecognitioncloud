      </div>
    </div>
  </section>

  <!-- TRIAL MODAL OVERLAY -->
  <div id="trial-modal" style="display:none;position:fixed;inset:0;z-index:1000;background:rgba(15,23,42,0.65);backdrop-filter:blur(3px);align-items:center;justify-content:center;padding:20px">
    <div style="background:#4338CA;border-radius:16px;max-width:680px;width:100%;padding:36px 32px;position:relative;box-shadow:0 24px 64px rgba(0,0,0,0.35)">
