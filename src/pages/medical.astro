  <!-- AC Form 293 submission script -->
  <script is:inline>
    (function(){
      var form = document.getElementById('_form_293_');
      if (!form) return;
      var thankYou = document.getElementById('_form_293_thank_you');

      function serialize(f) {
        var q = [];
        for (var i = 0; i < f.elements.length; i++) {
          var el = f.elements[i];
          if (!el.name) continue;
          if (el.type === 'submit' || el.type === 'button') continue;
          q.push(encodeURIComponent(el.name) + '=' + encodeURIComponent(el.value));
        }
        return q.join('&');
      }

      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var name = form.querySelector('[name="fullname"]');
        var email = form.querySelector('[name="email"]');
        if (!name.value.trim() || !email.value.trim()) return;
        if (!/^[^@]+@[^@]+\.[^@]+$/.test(email.value)) {
          email.style.borderColor = '#F37C7B';
          return;
        }
        var btn = document.getElementById('_form_293_submit');
        btn.disabled = true;
        btn.textContent = 'Submitting...';

        var data = serialize(form);
        var script = document.createElement('script');
        script.charset = 'utf-8';
        script.src = 'https://voicerecognition.activehosted.com/proc.php?' + data + '&jsonp=true';
        script.onerror = function() {
          btn.disabled = false;
          btn.textContent = 'Get started free';
          alert('Something went wrong. Please try again.');
        };
        document.head.appendChild(script);

        window._show_thank_you = function(id, message) {
          form.style.display = 'none';
          thankYou.style.display = 'block';
          thankYou.innerHTML = message || '<p style="font-size:18px;font-weight:600;margin-bottom:8px">You\'re in!</p><p style="font-size:14px;color:rgba(255,255,255,0.8)">Check your email for download instructions and your 30-day Medical Ultra access.</p>';
        };
      });
    })();
  </script>

  <!-- YouTube facade -->
  <script is:inline>
    document.querySelectorAll('.yt-facade').forEach(function(el){el.addEventListener('click',function(){var id=el.dataset.ytid;var iframe=document.createElement('iframe');iframe.src='https://www.youtube-nocookie.com/embed/'+id+'?autoplay=1&rel=0&modestbranding=1';iframe.allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';iframe.allowFullscreen=true;el.innerHTML='';el.appendChild(iframe);});});
  </script>
