  <style is:inline>
    .eyebrow{font-size:12px;font-weight:600;color:var(--brand);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:12px}
    .terms-section{margin-bottom:32px}
    .terms-section h2{font-size:18px;font-weight:700;margin-bottom:10px}
    .terms-section p{font-size:15px;line-height:1.7;color:var(--muted);margin-bottom:10px}
    .terms-section p:last-child{margin-bottom:0}
    .terms-list{list-style:none;margin:12px 0;padding:0}
    .terms-list li{font-size:15px;line-height:1.7;color:var(--muted);padding-left:20px;position:relative;margin-bottom:6px}
    .terms-list li::before{content:'';position:absolute;left:0;top:10px;width:6px;height:6px;border-radius:50%;background:var(--brand);opacity:0.4}
