---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../site.config.json';
const R2 = import.meta.env.PUBLIC_R2_BASE || '';

const extraSchema = [{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Free Voice to Text for Teachers — Dictation Software",
  "description": "Lesson plans, reports, and correspondence without the typing. Speech Recognition Cloud for teachers.",
  "url": site.siteUrl + "/teachers",
  "isPartOf": { "@type": "WebSite", "name": site.siteName, "url": site.siteUrl }
}];
---
<BaseLayout title="Free Voice to Text for Teachers — Dictation Software" description="Lesson plans, reports, and correspondence without the typing. Speech Recognition Cloud for teachers." extraSchema={extraSchema}>
  <section class="section-pad">
    <div class="container usecase-hero">
      <div>
        <p class="eyebrow">TEACHERS</p>
        <h1 style="font-size:clamp(28px,4vw,42px);font-weight:800;margin-bottom:16px">Less typing, more teaching</h1>
        <p class="muted" style="font-size:16px;line-height:1.7;margin-bottom:24px;max-width:500px">Dictate lesson plans, student reports, email correspondence, and documentation by voice. Works in any Windows application.</p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:12px"><a href={site.download.url} class="btn-primary">Download free</a><a href="/contact" class="btn-secondary">Contact us</a></div>
        <p class="muted" style="font-size:13px">No credit card required. Windows 10/11.</p>
      </div>
    </div>
  </section>
  <section class="section-pad section-neutral">
    <div class="container" style="max-width:800px">
      <h2 class="text-center" style="margin-bottom:40px">Built for educators</h2>
      <div class="benefit-grid">
        <div class="benefit"><h3>Dictate into any application</h3><p class="muted">Works at the cursor in Word, Outlook, student management systems, or any Windows application.</p></div>
        <div class="benefit"><h3>Student reports faster</h3><p class="muted">Dictate individual student comments and reports by voice. Full paragraphs with automatic punctuation.</p></div>
        <div class="benefit"><h3>Templates for repeated text</h3><p class="muted">Create templates for report card comments, email responses, and standard paragraphs. Insert by voice.</p></div>
        <div class="benefit"><h3>Custom vocabulary</h3><p class="muted">Add student names, subject-specific terms, and school terminology.</p></div>
        <div class="benefit"><h3>Affordable</h3><p class="muted">Free plan for occasional use. Personal plan at $79/year for unlimited dictation.</p></div>
        <div class="benefit"><h3>No training needed</h3><p class="muted">Install and start dictating immediately. No voice profiles or calibration.</p></div>
      </div>
    </div>
  </section>
  <section class="section-pad">
    <div class="container text-center" style="max-width:600px">
      <h2 style="margin-bottom:12px">Start with the free plan</h2>
      <p class="muted" style="margin-bottom:24px">20 minutes per month free. Upgrade to Personal for unlimited dictation at $79/year.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap"><a href="/pricing" class="btn-secondary">View pricing</a><a href={site.download.url} class="btn-primary">Download free</a></div>
    </div>
  </section>
  <style is:inline>
    .eyebrow{font-size:12px;font-weight:600;color:var(--brand);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:12px}
    .usecase-hero{max-width:700px}
    .benefit-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
    .benefit{padding:24px;border:1px solid var(--border);border-radius:14px;background:#fff}
    .benefit h3{font-size:16px;font-weight:600;margin-bottom:8px}
    .benefit .muted{font-size:14px;line-height:1.7}
    @media(max-width:768px){.benefit-grid{grid-template-columns:1fr}}
  </style>
</BaseLayout>
