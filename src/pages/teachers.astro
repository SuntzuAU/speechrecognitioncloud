---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../site.config.json';
---
<BaseLayout title="Teachers and educators" description="Lesson plans, reports, and correspondence without the typing. Speech Recognition Cloud for teachers.">
  <section class="section-pad">
    <div class="container usecase-hero">
      <div>
        <p class="eyebrow">TEACHERS</p>
        <h1 style="font-size:clamp(28px,4vw,42px);font-weight:800;margin-bottom:16px">Lesson plans, reports, and correspondence without the typing</h1>
        <p class="muted" style="font-size:16px;line-height:1.7;margin-bottom:24px;max-width:500px">Spend less time on admin and more time teaching. Dictate report comments, lesson plans, parent emails, and documentation by voice.</p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:12px"><a href={site.download.url} class="btn-primary">Download free</a><a href="/pricing" class="btn-secondary">View pricing</a></div>
        <p class="muted" style="font-size:13px">Free plan available. No credit card required.</p>
      </div>
    </div>
  </section>
  <section class="section-pad section-neutral">
    <div class="container" style="max-width:800px">
      <h2 class="text-center" style="margin-bottom:40px">Why teachers use SRC</h2>
      <div class="benefit-grid">
        <div class="benefit"><h3>Report writing made easier</h3><p class="muted">Dictate student report comments, progress notes, and assessments. Use templates to insert standard phrases and paragraphs by voice.</p></div>
        <div class="benefit"><h3>Lesson plans by voice</h3><p class="muted">Draft lesson plans, unit outlines, and curriculum documentation faster. Speak your ideas and let SRC handle the formatting.</p></div>
        <div class="benefit"><h3>Email and correspondence</h3><p class="muted">Reply to parent emails, write referrals, and draft correspondence without typing. Works in Outlook, Gmail, and any email client.</p></div>
        <div class="benefit"><h3>Affordable for educators</h3><p class="muted">Free plan with 20 minutes per month. Personal plan at $79/year for unlimited dictation. A fraction of what schools spend on other tools.</p></div>
        <div class="benefit"><h3>Works with school systems</h3><p class="muted">Dictate into Compass, SENTRAL, Google Classroom, and any web-based or Windows application your school uses.</p></div>
        <div class="benefit"><h3>Save hours every week</h3><p class="muted">Teachers who switch from typing to dictation report saving hours on administrative documentation each week.</p></div>
      </div>
    </div>
  </section>
  <section class="section-pad">
    <div class="container text-center" style="max-width:600px">
      <h2 style="margin-bottom:12px">Try it free</h2>
      <p class="muted" style="margin-bottom:24px">Download the free plan and try it with your next batch of reports.</p>
      <a href={site.download.url} class="btn-primary btn-lg">Download free</a>
    </div>
  </section>
  <style is:inline>
    .eyebrow{font-size:12px;font-weight:600;color:var(--brand);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:12px}
    .usecase-hero{max-width:700px}
    .btn-lg{padding:14px 36px;font-size:17px}
    .benefit-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
    .benefit{padding:24px;border:1px solid var(--border);border-radius:14px;background:#fff}
    .benefit h3{font-size:16px;font-weight:600;margin-bottom:8px}
    .benefit .muted{font-size:14px;line-height:1.7}
    @media(max-width:768px){.benefit-grid{grid-template-columns:1fr}}
  </style>
</BaseLayout>
