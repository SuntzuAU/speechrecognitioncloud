    .m-prose h3{font-size:20px;font-weight:700;margin:28px 0 12px;letter-spacing:-0.01em}
    .m-prose h4{font-size:17px;font-weight:700;margin:22px 0 8px}
    .m-prose p{font-size:16px;line-height:1.75;color:var(--text);margin:0 0 14px}
    .m-prose ul{margin:8px 0 18px 0;padding-left:22px}
