    .m-numbered{margin:8px 0 18px 0;padding-left:22px;display:flex;flex-direction:column;gap:14px}
    .m-numbered li{font-size:16px;line-height:1.75;color:var(--text)}

    .m-howto{list-style:none;padding:0;margin:8px 0 20px;counter-reset:howto;display:flex;flex-direction:column;gap:18px}
    .m-howto li{position:relative;padding:18px 20px;border:1px solid var(--border);border-radius:12px;background:#fff}
    .m-howto h3{margin:0 0 6px;font-size:16px;font-weight:700}
    .m-howto p{margin:0;font-size:15px;line-height:1.7}

    .m-regional-panel{padding:28px;border:1px solid var(--border);border-radius:14px;background:#fff}
    .m-regional-eyebrow{font-size:11px;font-weight:700;color:var(--muted);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:8px}
    .m-regional-panel h2{font-size:22px;font-weight:700;margin:0 0 14px;letter-spacing:-0.015em}
    .m-regional-panel p{font-size:15px;line-height:1.75;margin:0 0 12px;color:var(--text)}

    .m-author-panel{padding:24px 28px;border:1px solid var(--border);border-left:4px solid var(--brand);border-radius:12px;background:var(--brand-lightest)}
    .m-author-panel h2{font-size:20px;font-weight:700;margin:0 0 12px}
    .m-author-panel p{font-size:15px;line-height:1.75;margin:0 0 10px;color:var(--text)}
    .m-author-sig{font-weight:600}
    .m-reviewed{font-size:13px;margin-top:8px !important}

    .m-figure{margin:24px 0 28px;padding:0}
    .m-figure img{width:100%;max-width:820px;height:auto;border-radius:14px;object-fit:cover;box-shadow:0 12px 36px rgba(0,0,0,0.10);display:block}
    .m-figure figcaption{font-size:14px;color:var(--muted);font-style:italic;text-align:center;margin-top:10px;padding:0 8px;line-height:1.55}

    .benefit-list{display:flex;flex-direction:column;gap:28px}
    .benefit-rich{display:flex;gap:20px;padding:28px;border:1px solid var(--border);border-radius:14px;background:#fff}
    .benefit-icon{flex-shrink:0;width:48px;height:48px;display:flex;align-items:center;justify-content:center;background:#EEF2FF;border-radius:12px;margin-top:2px}
    .benefit-rich h3{font-size:17px;font-weight:700;margin:0 0 8px}
    .benefit-rich .muted{font-size:14px;line-height:1.75;margin:0}

    .yt-facade{position:relative;max-width:720px;margin:0 auto;cursor:pointer;border-radius:16px;overflow:hidden;background:#000;box-shadow:0 8px 32px rgba(0,0,0,0.12);aspect-ratio:16/9}
    .yt-facade img{width:100%;height:100%;object-fit:cover}
    .yt-facade .yt-play{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);opacity:0.9;transition:opacity 0.2s}
    .yt-facade:hover .yt-play{opacity:1}
    .yt-facade iframe{position:absolute;top:0;left:0;width:100%;height:100%;border:0}

    .faq-item{border-bottom:1px solid var(--border)}
    .faq-question{padding:16px 0;font-size:16px;font-weight:600;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:12px}
    .faq-question::-webkit-details-marker{display:none}
    .faq-question::after{content:'+';font-size:22px;color:var(--muted);font-weight:400;flex-shrink:0}
    .faq-item[open] .faq-question::after{content:'–'}
    .faq-answer{padding:0 0 16px}
    .faq-answer p{color:var(--muted);font-size:15px;line-height:1.75;margin:0}
    .m-faq-closer{margin-top:20px;font-size:14px;text-align:center}

    .btn-lg{padding:14px 36px;font-size:17px}

    @media(max-width:768px){
      .section-pad{padding:28px 0}
      .m-hero-split{grid-template-columns:1fr;gap:24px}
      .m-hero-img-wrap img{max-width:100%}
      .form-strip-inner{flex-direction:column;align-items:stretch;gap:16px;text-align:center}
      .form-strip-form{flex-direction:column}
      .form-strip-form input[type="text"],.form-strip-form input[type="email"]{min-width:auto;width:100%}
      .benefit-rich{flex-direction:column;gap:12px}
      .m-prose h2{font-size:22px}
      .m-prose h3{font-size:18px;margin-top:22px}
      .m-prose p, .m-prose ul li{font-size:15px}
      .m-author-panel{padding:22px}
      .m-regional-panel{padding:22px}
      .m-figure{margin:20px 0 24px}
      .m-figure figcaption{font-size:13px}
    }
  </style>

  <!-- AC Form 293 submission script (preserved verbatim) -->
  <script is:inline>
    (function(){
      var form = document.getElementById('_form_293_');
      if (!form) return;
      var thankYou = document.getElementById('_form_293_thank_you');

      function serialize(f) {
        var q = [];
        for (var i = 0; i < f.elements.length; i++) {
          var el = f.elements[i];
          if (!el.name) continue;
          if (el.type === 'submit' || el.type === 'button') continue;
          q.push(encodeURIComponent(el.name) + '=' + encodeURIComponent(el.value));
        }
        return q.join('&');
      }

      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var name = form.querySelector('[name="fullname"]');
        var email = form.querySelector('[name="email"]');
        if (!name.value.trim() || !email.value.trim()) return;
        if (!/^[^@]+@[^@]+\.[^@]+$/.test(email.value)) {
          email.style.borderColor = '#F37C7B';
          return;
        }
        var btn = document.getElementById('_form_293_submit');
        btn.disabled = true;
        btn.textContent = 'Submitting...';

        var data = serialize(form);
        var script = document.createElement('script');
        script.charset = 'utf-8';
        script.src = 'https://voicerecognition.activehosted.com/proc.php?' + data + '&jsonp=true';
        script.onerror = function() {
          btn.disabled = false;
          btn.textContent = 'Get started free';
          alert('Something went wrong. Please try again.');
        };
        document.head.appendChild(script);

        window._show_thank_you = function(id, message) {
          form.style.display = 'none';
          thankYou.style.display = 'block';
          thankYou.innerHTML = message || '<p style="font-size:18px;font-weight:600;margin-bottom:8px">You\'re in!</p><p style="font-size:14px;color:rgba(255,255,255,0.8)">Check your email for download instructions and your 30-day Professional access.</p>';
        };
      });
    })();
  </script>

  <!-- YouTube facade -->
  <script is:inline>
    document.querySelectorAll('.yt-facade').forEach(function(el){el.addEventListener('click',function(){var id=el.dataset.ytid;var iframe=document.createElement('iframe');iframe.src='https://www.youtube-nocookie.com/embed/'+id+'?autoplay=1&rel=0&modestbranding=1';iframe.allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';iframe.allowFullscreen=true;el.innerHTML='';el.appendChild(iframe);});});
  </script>
