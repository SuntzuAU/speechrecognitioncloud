---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../site.config.json';
const R2 = import.meta.env.PUBLIC_R2_BASE || '';

const extraSchema = [{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Speech to Text for Government",
  "description": "Secure dictation for policy, correspondence, and procurement documentation. Speech Recognition Cloud for government.",
  "url": site.siteUrl + "/government",
  "isPartOf": { "@type": "WebSite", "name": site.siteName, "url": site.siteUrl }
}];
---
<BaseLayout title="Speech to Text for Government" description="Secure dictation for policy, correspondence, and procurement documentation. Speech Recognition Cloud for government." extraSchema={extraSchema}>
  <section class="section-pad">
    <div class="container usecase-hero">
      <div>
        <p class="eyebrow">GOVERNMENT</p>
        <h1 style="font-size:clamp(28px,4vw,42px);font-weight:800;margin-bottom:16px">Secure dictation for government professionals</h1>
        <p class="muted" style="font-size:16px;line-height:1.7;margin-bottom:24px;max-width:500px">Dictate policy documents, ministerial correspondence, procurement submissions, and case notes directly into any Windows application. Audio is never stored.</p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:12px"><a href={site.download.url} class="btn-primary">Download free</a><a href="/contact" class="btn-secondary">Contact us</a></div>
        <p class="muted" style="font-size:13px">No credit card required. Windows 10/11.</p>
      </div>
    </div>
  </section>
  <section class="section-pad section-neutral">
    <div class="container" style="max-width:800px">
      <h2 class="text-center" style="margin-bottom:40px">Built for government workflows</h2>
      <div class="benefit-grid">
        <div class="benefit"><h3>Works with any application</h3><p class="muted">Dictate at the cursor in Outlook, Word, case management systems, or any Windows-based application used in government.</p></div>
        <div class="benefit"><h3>Privacy and security</h3><p class="muted">Audio is processed and immediately discarded. No recordings are stored. Your data is never used to train AI models. All connections encrypted.</p></div>
        <div class="benefit"><h3>Custom vocabulary</h3><p class="muted">Add department-specific terminology, legislation references, acronyms, and names.</p></div>
        <div class="benefit"><h3>Templates for standard documents</h3><p class="muted">Create templates for ministerial correspondence, briefs, and standard paragraphs. Insert by voice command.</p></div>
        <div class="benefit"><h3>No voice training</h3><p class="muted">Install and start dictating immediately. No voice profiles or calibration required.</p></div>
        <div class="benefit"><h3>Volume licensing</h3><p class="muted">Contact us for volume pricing and invoicing for departmental deployments.</p></div>
      </div>
    </div>
  </section>
  <section class="section-pad">
    <div class="container text-center" style="max-width:600px">
      <h2 style="margin-bottom:12px">Start with the free plan</h2>
      <p class="muted" style="margin-bottom:24px">Try Speech Recognition Cloud free. Upgrade to Professional for templates, AI modes, and Ultra Accuracy.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap"><a href="/pricing" class="btn-secondary">View pricing</a><a href={site.download.url} class="btn-primary">Download free</a></div>
    </div>
  </section>
  <style is:inline>
    .eyebrow{font-size:12px;font-weight:600;color:var(--brand);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:12px}
    .usecase-hero{max-width:700px}
    .benefit-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
    .benefit{padding:24px;border:1px solid var(--border);border-radius:14px;background:#fff}
    .benefit h3{font-size:16px;font-weight:600;margin-bottom:8px}
    .benefit .muted{font-size:14px;line-height:1.7}
    @media(max-width:768px){.benefit-grid{grid-template-columns:1fr}}
  </style>
</BaseLayout>
