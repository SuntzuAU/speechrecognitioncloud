---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../site.config.json';
---
<BaseLayout title="Government" description="Secure dictation for policy, correspondence, and procurement documentation. Speech Recognition Cloud for government.">
  <section class="section-pad">
    <div class="container usecase-hero">
      <div>
        <p class="eyebrow">GOVERNMENT</p>
        <h1 style="font-size:clamp(28px,4vw,42px);font-weight:800;margin-bottom:16px">Secure dictation for government professionals</h1>
        <p class="muted" style="font-size:16px;line-height:1.7;margin-bottom:24px;max-width:500px">Dictate policy documents, ministerial correspondence, procurement documentation, and briefings. Works with any Windows application. Audio is not stored. Data is not used for training.</p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:12px"><a href={site.download.url} class="btn-primary">Download free</a><a href="/contact" class="btn-secondary">Contact us</a></div>
        <p class="muted" style="font-size:13px">No credit card required. Windows 10/11.</p>
      </div>
    </div>
  </section>
  <section class="section-pad section-neutral">
    <div class="container" style="max-width:800px">
      <h2 class="text-center" style="margin-bottom:40px">Built for government requirements</h2>
      <div class="benefit-grid">
        <div class="benefit"><h3>Data handling transparency</h3><p class="muted">Audio is processed and immediately discarded. Text is not stored on our servers. Your data is never used for AI model training. Clear data handling you can document for compliance.</p></div>
        <div class="benefit"><h3>Works with existing systems</h3><p class="muted">Dictate at the cursor in any Windows application. No special integrations required. Works with your existing document management and correspondence systems.</p></div>
        <div class="benefit"><h3>No cloud storage of content</h3><p class="muted">Unlike some tools, SRC does not store transcripts, recordings, or user content. Text goes directly to your cursor and stays on your device.</p></div>
        <div class="benefit"><h3>Volume licensing</h3><p class="muted">Contact us for volume pricing, invoicing, and procurement-friendly purchasing for teams and departments.</p></div>
        <div class="benefit"><h3>Australian company</h3><p class="muted">Built by Voice Recognition Australia, a 26-year Australian company. Local support, local expertise.</p></div>
        <div class="benefit"><h3>Encryption in transit</h3><p class="muted">All connections between your device and our processing servers are encrypted using industry-standard TLS.</p></div>
      </div>
    </div>
  </section>
  <section class="section-pad">
    <div class="container text-center" style="max-width:600px">
      <h2 style="margin-bottom:12px">Enquire about government licensing</h2>
      <p class="muted" style="margin-bottom:24px">We offer volume pricing and can work with your procurement processes.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap"><a href="/contact" class="btn-primary">Contact us</a><a href="/pricing" class="btn-secondary">View pricing</a></div>
    </div>
  </section>
  <style is:inline>
    .eyebrow{font-size:12px;font-weight:600;color:var(--brand);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:12px}
    .usecase-hero{max-width:700px}
    .benefit-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
    .benefit{padding:24px;border:1px solid var(--border);border-radius:14px;background:#fff}
    .benefit h3{font-size:16px;font-weight:600;margin-bottom:8px}
    .benefit .muted{font-size:14px;line-height:1.7}
    @media(max-width:768px){.benefit-grid{grid-template-columns:1fr}}
  </style>
</BaseLayout>
