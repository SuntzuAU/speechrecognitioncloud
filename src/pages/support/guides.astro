---
import BaseLayout from '../../layouts/BaseLayout.astro';
import site from '../../site.config.json';

// All downloadable PDF guides. To add a new guide, drop the PDF in
// public/guides/ and add an entry here. Use clean filenames with no spaces.
const guides = [
  { title: "Installation Guide", description: "Download, install, and activate Speech Recognition Cloud on your Windows PC.", file: "/guides/SRC-Installation-Guide.pdf" },
  { title: "User Guide", description: "The complete guide to setting up and dictating with Speech Recognition Cloud.", file: "/guides/SRC-User-Guide.pdf" },
  { title: "Microphone Guide", description: "Choose and set up your microphone for the best possible dictation accuracy.", file: "/guides/SRC-Microphone-Guide.pdf" },
  { title: "Hotkeys Guide", description: "Set and customise the hotkeys that start and stop your dictation.", file: "/guides/SRC-Hotkeys-Guide.pdf" },
  { title: "AI Modes Guide", description: "Write, Rewrite, Answer, Reply, and Run Command — how to use the AI-powered voice modes.", file: "/guides/SRC-AI-Modes-Guide.pdf" },
  { title: "Text Replacements Guide", description: "Auto-replace words and phrases, expand abbreviations, fix common errors, and insert templates.", file: "/guides/SRC-Replacements-Guide.pdf" },
  { title: "Vocabulary Guide", description: "Add specialised terms, names, and jargon so the transcription engine recognises your words.", file: "/guides/SRC-Vocabulary-Guide.pdf" },
  { title: "General Tab Guide", description: "The General settings tab — account, usage, and core application options.", file: "/guides/SRC-General-Tab-Guide.pdf" },
  { title: "Preferences Guide", description: "Configure preferences: startup behaviour, minimising to tray, and general options.", file: "/guides/SRC-Preferences-Guide.pdf" },
  { title: "Advanced Settings Guide", description: "Advanced configuration options for power users who want finer control over the app.", file: "/guides/SRC-Advanced-Settings-Guide.pdf" },
  { title: "History Guide", description: "Review, search, and reuse your previous dictations from the history panel.", file: "/guides/SRC-History-Guide.pdf" },
  { title: "Mobile App Guide", description: "Set up the iPhone or Android companion app as a wireless mic or for Voice Notes on the go.", file: "/guides/SRC-Smartphone-Guide.pdf" },
  { title: "Administrator Guide", description: "Deployment, licensing, and configuration for IT administrators and volume rollouts.", file: "/guides/SRC-Administrator-Guide.pdf" },
];
---
<BaseLayout title="Guides" description="Download PDF user guides for Speech Recognition Cloud — user guide, AI modes, text replacements, vocabulary, mobile app, and more.">
  <section class="section-pad">
    <div class="container" style="max-width:960px">
      <p class="eyebrow">SUPPORT</p>
      <h1 style="font-size:clamp(28px,4vw,40px);font-weight:800;margin-bottom:12px">Guides</h1>
      <p class="muted" style="font-size:16px;margin-bottom:40px">Download printable PDF guides for Speech Recognition Cloud. Each one covers a specific feature in detail — click to open or download.</p>

      <div class="guides-grid">
        {guides.map(g => (
          <a href={g.file} class="guide-card" target="_blank" rel="noopener">
            <div class="guide-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><polyline points="9 15 12 18 15 15"/></svg>
            </div>
            <div class="guide-body">
              <h3 class="guide-title">{g.title}</h3>
              <p class="guide-desc muted">{g.description}</p>
              <span class="guide-link">Download PDF &rarr;</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad section-neutral">
    <div class="container text-center" style="max-width:600px">
      <h2 style="margin-bottom:12px">Prefer to watch?</h2>
      <p class="muted" style="margin-bottom:24px">See features in action in our video walkthroughs.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
        <a href="/support/videos" class="btn-secondary">Watch videos</a>
        <a href="/support" class="btn-primary">Back to support</a>
      </div>
    </div>
  </section>

  <style is:inline>
    .eyebrow{font-size:12px;font-weight:600;color:var(--brand);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:12px}
    .guides-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px}
    .guide-card{display:flex;gap:16px;padding:22px;border:1px solid var(--border);border-radius:14px;background:var(--bg);transition:border-color 0.15s,box-shadow 0.15s,transform 0.1s}
    .guide-card:hover{border-color:var(--brand-light);box-shadow:0 10px 28px rgba(67,56,202,0.08);transform:translateY(-2px)}
    .guide-icon{flex:none;width:44px;height:44px;border-radius:10px;background:var(--brand-lightest);color:var(--brand);display:flex;align-items:center;justify-content:center}
    .guide-title{font-size:17px;font-weight:700;margin-bottom:6px}
    .guide-desc{font-size:14px;line-height:1.55;margin-bottom:10px}
    .guide-link{font-size:14px;font-weight:600;color:var(--brand)}
    @media (max-width:640px){.guides-grid{grid-template-columns:1fr}}
  </style>
</BaseLayout>
