---
import BaseLayout from '../../layouts/BaseLayout.astro';
import site from '../../site.config.json';

// Video walkthroughs. To add a video, paste the YouTube ID (the part after
// youtu.be/) plus a title and short description.
const videos = [
  { title: "Introduction to Speech Recognition Cloud", description: "A quick demo of dictating into any Windows application.", youtubeId: "vp0LFuRWdKI" },
  { title: "Getting started", description: "From download to your first dictation in a few minutes.", youtubeId: "eg2rq2Y8xUA" },
  { title: "AI Modes (Professional edition)", description: "Write, Rewrite, Answer, Reply, and Run Command in action.", youtubeId: "5YlOzjs_paA" },
  { title: "Configuring options", description: "How to set up and configure the options to suit how you work.", youtubeId: "mPIF2Js7mbA" },
  { title: "Text replacements & vocabulary", description: "Auto-replace phrases and add custom vocabulary so your terms are recognised.", youtubeId: "uCoHZFkfv-k" },
  { title: "Mobile setup — iPhone", description: "Set up the companion app on iPhone as a wireless mic or for Voice Notes.", youtubeId: "9VuQS-AsBQg" },
  { title: "Mobile setup — Android", description: "Set up the companion app on Android as a wireless mic or for Voice Notes.", youtubeId: "VPDzk5Glanw" },
];
---
<BaseLayout title="Videos" description="Video walkthroughs for Speech Recognition Cloud — intro demo, getting started, AI modes, options, and mobile setup.">
  <section class="section-pad">
    <div class="container" style="max-width:940px">
      <p class="eyebrow">SUPPORT</p>
      <h1 style="font-size:clamp(28px,4vw,40px);font-weight:800;margin-bottom:12px">Videos</h1>
      <p class="muted" style="font-size:16px;margin-bottom:40px">Watch short walkthroughs of Speech Recognition Cloud features and setup. Click a video to play it.</p>

      <div class="video-grid">
        {videos.map(v => (
          <div class="video-item">
            <div class="yt-facade" data-ytid={v.youtubeId}>
              <img src={`https://i.ytimg.com/vi/${v.youtubeId}/hqdefault.jpg`} alt={v.title} loading="lazy" decoding="async" />
              <div class="yt-play"><svg viewBox="0 0 68 48" width="60" height="42"><path d="M66.5 7.7c-.8-2.9-2.5-5.4-5.4-6.2C55.8.1 34 0 34 0S12.2.1 6.9 1.6c-2.8.7-4.6 3.2-5.4 6.1C.1 13 0 24 0 24s0 11 1.5 16.3c.8 2.9 2.6 5.4 5.4 6.2C12.2 47.9 34 48 34 48s21.8-.1 27.1-1.6c2.8-.7 4.6-3.2 5.4-6.1C67.9 35 68 24 68 24s0-11-1.5-16.3z" fill="#FF0000"/><path d="M27 34V14l18 10-18 10z" fill="#FFF"/></svg></div>
            </div>
            <h3 class="video-title">{v.title}</h3>
            <p class="muted" style="font-size:14px">{v.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad section-neutral">
    <div class="container text-center" style="max-width:600px">
      <h2 style="margin-bottom:12px">Prefer to read?</h2>
      <p class="muted" style="margin-bottom:24px">Download our detailed PDF guides for every feature.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
        <a href="/support/guides" class="btn-secondary">Browse guides</a>
        <a href="/support" class="btn-primary">Back to support</a>
      </div>
    </div>
  </section>

  <style is:inline>
    .eyebrow{font-size:12px;font-weight:600;color:var(--brand);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:12px}
    .video-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:32px 24px}
    .video-title{font-size:17px;font-weight:700;margin:14px 0 6px}
    .yt-facade{position:relative;width:100%;cursor:pointer;border-radius:14px;overflow:hidden;background:#000;box-shadow:0 6px 24px rgba(0,0,0,0.1);aspect-ratio:16/9}
    .yt-facade img{width:100%;height:100%;object-fit:cover;display:block}
    .yt-facade .yt-play{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);opacity:0.9;transition:opacity 0.2s}
    .yt-facade:hover .yt-play{opacity:1}
    .yt-facade iframe{position:absolute;top:0;left:0;width:100%;height:100%;border:0}
    @media(max-width:640px){.video-grid{grid-template-columns:1fr}}
  </style>
  <script is:inline>
    document.querySelectorAll('.yt-facade').forEach(function(el){el.addEventListener('click',function(){var id=el.dataset.ytid;var iframe=document.createElement('iframe');iframe.src='https://www.youtube-nocookie.com/embed/'+id+'?autoplay=1&rel=0&modestbranding=1';iframe.allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';iframe.allowFullscreen=true;el.innerHTML='';el.appendChild(iframe);});});
  </script>
</BaseLayout>
