---
import BaseLayout from '../../layouts/BaseLayout.astro';
import site from '../../site.config.json';
---
<BaseLayout title="Mobile setup" description="Set up the Speech Recognition Cloud mobile companion app on iPhone or Android. Available on Professional and Medical plans.">
  <section class="section-pad">
    <div class="container" style="max-width:820px">
      <p class="eyebrow">SUPPORT</p>
      <h1 style="font-size:clamp(28px,4vw,40px);font-weight:800;margin-bottom:12px">Mobile setup</h1>
      <p class="muted" style="font-size:16px;margin-bottom:16px">Speech Recognition Cloud includes a mobile companion app so you can dictate from your phone and have the transcribed text appear on your Windows PC. The mobile app is available for iPhone and Android.</p>
      <p class="muted" style="font-size:14px;margin-bottom:40px">The mobile companion is available on the <a href="/pricing" style="color:var(--brand);font-weight:600">Professional and Medical plans</a>. Choose your platform below and follow along with the setup video.</p>

      <div class="platform-section">
        <div class="platform-header">
          <div class="platform-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#4338CA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 18.5a.5.5 0 100 1 .5.5 0 000-1z"/><rect x="5" y="2" width="14" height="20" rx="2.5" ry="2.5"/></svg>
          </div>
          <div>
            <h2 style="margin:0;font-size:24px;font-weight:700">iPhone setup</h2>
            <p class="muted" style="margin:4px 0 0;font-size:14px">For iOS devices. Approximately 5 minutes.</p>
          </div>
        </div>

        <div class="yt-facade" data-ytid="AIg0Eb4J-gg">
          <img src="https://i.ytimg.com/vi/AIg0Eb4J-gg/maxresdefault.jpg" alt="Speech Recognition Cloud iPhone setup video" loading="lazy" decoding="async" />
          <div class="yt-play"><svg viewBox="0 0 68 48" width="68" height="48"><path d="M66.5 7.7c-.8-2.9-2.5-5.4-5.4-6.2C55.8.1 34 0 34 0S12.2.1 6.9 1.6c-2.8.7-4.6 3.2-5.4 6.1C.1 13 0 24 0 24s0 11 1.5 16.3c.8 2.9 2.6 5.4 5.4 6.2C12.2 47.9 34 48 34 48s21.8-.1 27.1-1.6c2.8-.7 4.6-3.2 5.4-6.1C67.9 35 68 24 68 24s0-11-1.5-16.3z" fill="#FF0000"/><path d="M27 34V14l18 10-18 10z" fill="#FFF"/></svg></div>
        </div>

        <div class="steps-block">
          <h3 style="margin-bottom:16px;font-size:17px">Quick reference</h3>
          <div class="steps">
            <div class="step"><span class="step-num">1</span><div><p>Install Speech Recognition Cloud on your Windows PC and sign in to your Professional or Medical account</p></div></div>
            <div class="step"><span class="step-num">2</span><div><p>Download the Speech Recognition Cloud companion app from the App Store on your iPhone</p></div></div>
            <div class="step"><span class="step-num">3</span><div><p>Open the app and sign in with the same account you use on your PC</p></div></div>
            <div class="step"><span class="step-num">4</span><div><p>Pair your phone with your PC by following the in-app prompts</p></div></div>
            <div class="step"><span class="step-num">5</span><div><p>Start dictating from your phone. Transcribed text will appear at your cursor on your PC</p></div></div>
          </div>
          <p class="muted" style="margin-top:16px;font-size:14px">Watch the video above for the full walkthrough including troubleshooting and pairing tips.</p>
        </div>
      </div>

      <div class="platform-section">
        <div class="platform-header">
          <div class="platform-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#4338CA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          </div>
          <div>
            <h2 style="margin:0;font-size:24px;font-weight:700">Android setup</h2>
            <p class="muted" style="margin:4px 0 0;font-size:14px">For Android devices. Approximately 5 minutes.</p>
          </div>
        </div>

        <div class="yt-facade" data-ytid="VPDzk5Glanw">
          <img src="https://i.ytimg.com/vi/VPDzk5Glanw/maxresdefault.jpg" alt="Speech Recognition Cloud Android setup video" loading="lazy" decoding="async" />
          <div class="yt-play"><svg viewBox="0 0 68 48" width="68" height="48"><path d="M66.5 7.7c-.8-2.9-2.5-5.4-5.4-6.2C55.8.1 34 0 34 0S12.2.1 6.9 1.6c-2.8.7-4.6 3.2-5.4 6.1C.1 13 0 24 0 24s0 11 1.5 16.3c.8 2.9 2.6 5.4 5.4 6.2C12.2 47.9 34 48 34 48s21.8-.1 27.1-1.6c2.8-.7 4.6-3.2 5.4-6.1C67.9 35 68 24 68 24s0-11-1.5-16.3z" fill="#FF0000"/><path d="M27 34V14l18 10-18 10z" fill="#FFF"/></svg></div>
        </div>

        <div class="steps-block">
          <h3 style="margin-bottom:16px;font-size:17px">Quick reference</h3>
          <div class="steps">
            <div class="step"><span class="step-num">1</span><div><p>Install Speech Recognition Cloud on your Windows PC and sign in to your Professional or Medical account</p></div></div>
            <div class="step"><span class="step-num">2</span><div><p>Download the Speech Recognition Cloud companion app from Google Play on your Android device</p></div></div>
            <div class="step"><span class="step-num">3</span><div><p>Open the app and sign in with the same account you use on your PC</p></div></div>
            <div class="step"><span class="step-num">4</span><div><p>Pair your phone with your PC by following the in-app prompts</p></div></div>
            <div class="step"><span class="step-num">5</span><div><p>Start dictating from your phone. Transcribed text will appear at your cursor on your PC</p></div></div>
          </div>
          <p class="muted" style="margin-top:16px;font-size:14px">Watch the video above for the full walkthrough including troubleshooting and pairing tips.</p>
        </div>
      </div>

      <div class="info-callout">
        <h3 style="margin-bottom:8px;font-size:16px;font-weight:600">Having trouble?</h3>
        <p class="muted" style="font-size:14px;margin-bottom:8px">Both apps need to be signed in to the same Speech Recognition Cloud account, and both devices should be online when pairing. If pairing fails, close both apps, reopen them, and try again.</p>
        <p class="muted" style="font-size:14px">Still stuck? <a href="/contact" style="color:var(--brand);font-weight:600">Contact us</a> and we'll help you get it working.</p>
      </div>

    </div>
  </section>
  <section class="section-pad section-neutral">
    <div class="container text-center" style="max-width:600px">
      <h2 style="margin-bottom:12px">Need Professional or Medical?</h2>
      <p class="muted" style="margin-bottom:24px">The mobile companion is included on Professional ($159/year) and Medical ($439/year) plans.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
        <a href="/pricing" class="btn-secondary">View plans</a>
        <a href={site.download.url} class="btn-primary">Download free</a>
      </div>
    </div>
  </section>
  <style is:inline>
    .eyebrow{font-size:12px;font-weight:600;color:var(--brand);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:12px}
    .platform-section{margin-bottom:64px;padding-bottom:48px;border-bottom:1px solid var(--border)}
    .platform-section:last-of-type{border-bottom:0}
    .platform-header{display:flex;align-items:center;gap:16px;margin-bottom:24px}
    .platform-icon{width:56px;height:56px;background:var(--brand-lightest, #EEF2FF);border-radius:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .yt-facade{position:relative;width:100%;margin-bottom:32px;cursor:pointer;border-radius:14px;overflow:hidden;background:#000;box-shadow:0 6px 24px rgba(0,0,0,0.1);aspect-ratio:16/9}
    .yt-facade img{width:100%;height:100%;object-fit:cover;display:block}
    .yt-facade .yt-play{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);opacity:0.9;transition:opacity 0.2s}
    .yt-facade:hover .yt-play{opacity:1}
    .yt-facade iframe{position:absolute;top:0;left:0;width:100%;height:100%;border:0}
    .steps-block{padding:24px;background:var(--neutral);border-radius:14px}
    .steps{display:flex;flex-direction:column;gap:14px}
    .step{display:flex;gap:14px;align-items:flex-start}
    .step-num{width:32px;height:32px;background:var(--brand);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;flex-shrink:0}
    .step p{font-size:15px;line-height:1.6;margin:4px 0 0}
    .info-callout{padding:20px 24px;background:var(--brand-lightest, #EEF2FF);border-radius:12px;border-left:4px solid var(--brand)}
    @media(max-width:600px){.platform-header{gap:12px}.platform-icon{width:48px;height:48px}.platform-header h2{font-size:20px !important}}
  </style>
  <script is:inline>
    document.querySelectorAll('.yt-facade').forEach(function(el){el.addEventListener('click',function(){var id=el.dataset.ytid;var iframe=document.createElement('iframe');iframe.src='https://www.youtube-nocookie.com/embed/'+id+'?autoplay=1&rel=0&modestbranding=1';iframe.allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';iframe.allowFullscreen=true;el.innerHTML='';el.appendChild(iframe);});});
  </script>
</BaseLayout>
