---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../site.config.json';

const extraSchema = [{
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Speech Recognition Cloud",
  "description": "Get in touch with the Speech Recognition Cloud team for support, sales enquiries, or volume licensing.",
  "url": site.siteUrl + "/contact",
  "isPartOf": { "@type": "WebSite", "name": site.siteName, "url": site.siteUrl }
}];
---
<BaseLayout title="Contact us" description="Get in touch with the Speech Recognition Cloud team for support, sales enquiries, or volume licensing." extraSchema={extraSchema}>
  <section class="section-pad">
    <div class="container" style="max-width:600px">
      <h1 style="font-size:clamp(28px,4vw,42px);font-weight:800;margin-bottom:12px;text-align:center">Contact us</h1>
      <p class="muted text-center" style="margin-bottom:36px">Questions about Speech Recognition Cloud? Need help getting set up? Want volume pricing? Get in touch.</p>

      <!-- AC hosted form 291 - speechrecognition.cloud contact form. -->
      <!-- reCAPTCHA is configured on AC form 291 backend (sitekey 6LcwIw8TAAAAACP1ysM08EhCgzd6q5JAOUR1a0Go). -->
      <div class="_form_291"></div>
      <script src="https://voicerecognition.activehosted.com/f/embed.php?id=291" charset="utf-8" is:inline></script>
    </div>
  </section>
</BaseLayout>

