---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../site.config.json';
const R2 = import.meta.env.PUBLIC_R2_BASE || '';

const extraSchema = [{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Speech to Text for Accessibility and RSI",
  "description": "Reduce keyboard use. An alternative input method for anyone with motor limitations or repetitive strain injury.",
  "url": site.siteUrl + "/accessibility",
  "isPartOf": { "@type": "WebSite", "name": site.siteName, "url": site.siteUrl }
}];
---
<BaseLayout title="Speech to Text for Accessibility and RSI" description="Reduce keyboard use. An alternative input method for anyone with motor limitations or repetitive strain injury." extraSchema={extraSchema}>
  <section class="section-pad">
    <div class="container usecase-hero">
      <div>
        <p class="eyebrow">ACCESSIBILITY</p>
        <h1 style="font-size:clamp(28px,4vw,42px);font-weight:800;margin-bottom:16px">Type less. Speak instead.</h1>
        <p class="muted" style="font-size:16px;line-height:1.7;margin-bottom:24px;max-width:500px">An alternative to the keyboard for anyone with RSI, motor limitations, or who simply needs to reduce typing. Dictate into any Windows application.</p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:12px"><a href={site.download.url} class="btn-primary">Download free</a><a href="/contact" class="btn-secondary">Contact us</a></div>
        <p class="muted" style="font-size:13px">Free plan available. No credit card required. Windows 10/11.</p>
      </div>
    </div>
  </section>
  <section class="section-pad section-neutral">
    <div class="container" style="max-width:800px">
      <h2 class="text-center" style="margin-bottom:40px">Built for accessibility</h2>
      <div class="benefit-grid">
        <div class="benefit"><h3>Reduce keyboard use</h3><p class="muted">Dictate emails, documents, and messages by voice. Significantly reduce the amount of typing you need to do each day.</p></div>
        <div class="benefit"><h3>Works in any application</h3><p class="muted">Dictate at the cursor in Word, Outlook, web browsers, or any Windows application. No special accessibility plugins needed.</p></div>
        <div class="benefit"><h3>AI punctuation</h3><p class="muted">Speak naturally. The AI adds punctuation and formatting automatically so you do not need to type corrections.</p></div>
        <div class="benefit"><h3>Free plan available</h3><p class="muted">20 minutes per month free. No credit card required. Upgrade to unlimited for $79/year.</p></div>
        <div class="benefit"><h3>No training needed</h3><p class="muted">Install and start dictating immediately. No voice profiles, no calibration, no setup wizards.</p></div>
        <div class="benefit"><h3>Works with accents</h3><p class="muted">Cloud AI handles accent variation well. Designed for diverse speakers and real-world environments.</p></div>
      </div>
    </div>
  </section>
  <section class="section-pad">
    <div class="container text-center" style="max-width:600px">
      <h2 style="margin-bottom:12px">Start free today</h2>
      <p class="muted" style="margin-bottom:24px">Free plan with 20 minutes per month. No credit card required.</p>
      <a href={site.download.url} class="btn-primary">Download free</a>
    </div>
  </section>
  <style is:inline>
    .eyebrow{font-size:12px;font-weight:600;color:var(--brand);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:12px}
    .usecase-hero{max-width:700px}
    .benefit-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:24px}
    .benefit{padding:24px;border:1px solid var(--border);border-radius:14px;background:#fff}
    .benefit h3{font-size:16px;font-weight:600;margin-bottom:8px}
    .benefit .muted{font-size:14px;line-height:1.7}
    @media(max-width:768px){.benefit-grid{grid-template-columns:1fr}}
  </style>
</BaseLayout>
