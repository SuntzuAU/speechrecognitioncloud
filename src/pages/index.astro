---
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../site.config.json';
import manifest from '../data/image-manifest.json';
const c = site.colours;
const R2 = import.meta.env.PUBLIC_R2_BASE || '';

function imgSrc(key) {
  const entry = manifest[key];
  if (!entry?.r2Key || !R2) return '';
  return `${R2.replace(/\/$/, '')}/${entry.r2Key}`;
}
function imgAlt(key) {
  return manifest[key]?.altText || key;
}

// SoftwareApplication schema
const softwareSchema = {
  "@context": "https://schema.org",
  "@type": site.structuredData.type,
  "name": site.structuredData.name,
  "description": site.structuredData.description,
  "applicationCategory": site.structuredData.applicationCategory,
  "operatingSystem": site.structuredData.operatingSystem,
  "downloadUrl": site.structuredData.downloadUrl,
  "url": site.siteUrl,
  "offers": site.structuredData.offers.map(o => ({
    "@type": "Offer",
    "price": o.price,
    "priceCurrency": o.priceCurrency,
    "description": o.description
  })),
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "ratingCount": "47",
    "bestRating": "5"
  }
};

// FAQPage schema from homepage FAQ
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": site.faq.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const extraSchema = [softwareSchema, faqSchema];
---
<BaseLayout extraSchema={extraSchema}>
  <!-- 1. HERO -->
  <section class="hero">
    <div class="container hero-split">
      <div class="hero-text">
        <p class="hero-eyebrow">AI VOICE DICTATION FOR WINDOWS</p>
        <h1 class="hero-headline">{site.hero.headline}<br/><span class="accent">{site.hero.headlineAccent}</span></h1>
        <p class="hero-sub">{site.hero.subheadline}</p>
        <ul class="hero-bullets">
          {site.hero.bullets.map(b => (<li><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><circle cx="10" cy="10" r="10" fill="#4338CA" opacity="0.12"/><path d="M6 10l3 3 5-5" stroke="#4338CA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>{b}</li>))}
        </ul>
        <div class="hero-ctas">
          <a href={site.hero.ctaPrimaryUrl} class="btn-primary btn-lg">{site.hero.ctaPrimary}</a>
          <a href={site.hero.ctaSecondaryUrl} class="btn-secondary">{site.hero.ctaSecondary}</a>
        </div>
        <p class="hero-micro">{site.hero.microcopy}</p>
      </div>
      <div class="hero-visual">
        <div class="hero-product">
          <video autoplay muted loop playsinline preload="auto">
            <source src={`${R2}/speechrecognitioncloud/2026/03/video/speech-to-text-free.mp4`} type="video/mp4" />
          </video>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. CLARITY STRIP -->
  <section class="clarity-strip">
    <div class="container"><div class="clarity-grid">{site.clarityStrip.items.map(item => (<div class="clarity-item"><span class="clarity-label">{item.label}</span><span class="clarity-value">{item.value}</span></div>))}</div></div>
  </section>

  <!-- 3. STATS -->
  <section class="stats-section" id="proof">
    <div class="container">
      <div class="stats-grid">{site.stats.map(s => (<div class="stat-card"><span class="stat-value accent">{s.value}</span><span class="stat-label">{s.label}</span></div>))}</div>
    </div>
  </section>

  <!-- 4. FOUNDER CREDIBILITY -->
  <section class="section-pad section-dark" id="credibility">
    <div class="container">
      <div class="founder-layout">
        <div class="founder-quote-area">
          <blockquote class="founder-quote">
            <p>"{site.credibility.quote}"</p>
          </blockquote>
          <div class="founder-attribution">
            <div class="founder-avatar">
              <span class="founder-initials">RB</span>
            </div>
            <div>
              <strong style="font-size:16px;display:block">{site.credibility.founderName}</strong>
              <span class="muted" style="font-size:14px">{site.credibility.founderTitle}</span>
              {site.credibility.founderLinkedIn && <a href={site.credibility.founderLinkedIn} target="_blank" rel="noopener noreferrer" style="font-size:13px;color:var(--dark-accent);margin-left:12px">LinkedIn</a>}
            </div>
          </div>
        </div>
        <div class="founder-credentials">
          <ul class="credibility-points">
            {site.credibility.credentials.map(point => (<li><svg width="18" height="18" viewBox="0 0 18 18" fill="none"><circle cx="9" cy="9" r="9" fill="#818CF8" opacity="0.15"/><path d="M5.5 9l2.5 2.5 4.5-4.5" stroke="#818CF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg><span>{point}</span></li>))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. USE CASES -->
  <section class="section-pad section-neutral" id="use-cases">
    <div class="container">
      <h2 class="text-center" style="margin-bottom:12px">Built for how you work</h2>
      <p class="text-center muted" style="margin-bottom:48px;max-width:600px;margin-left:auto;margin-right:auto">Speech Recognition Cloud adapts to your profession. Choose your field to see how it fits your workflow.</p>
      <div class="usecase-grid">
        {site.useCaseCards.map(uc => {
          const slug = uc.href.replace(/^\//,'');
          const cardImgKey = `usecase-${slug}`;
          return (
            <a href={uc.href} class="usecase-card">
              {imgSrc(cardImgKey) && (
                <div class="usecase-card-img">
                  <img src={imgSrc(cardImgKey)} alt={imgAlt(cardImgKey)} loading="lazy" decoding="async" />
                </div>
              )}
              <div class="usecase-card-body">
                <h3>{uc.title}</h3>
                <p class="muted">{uc.description}</p>
                <span class="usecase-arrow accent">Learn more &rarr;</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 6. DEMO VIDEO -->
  <section class="section-pad" id="demo">
    <div class="container text-center">
      <h2 style="margin-bottom:8px">See it in action</h2>
      <p class="muted" style="font-size:16px;margin-bottom:24px">{site.demo.caption}</p>
      <div class="yt-facade" data-ytid={site.demo.youtubeId}>
        <img src={`https://i.ytimg.com/vi/${site.demo.youtubeId}/maxresdefault.jpg`} alt="Speech Recognition Cloud demo video" loading="lazy" decoding="async" />
        <div class="yt-play"><svg viewBox="0 0 68 48" width="68" height="48"><path d="M66.5 7.7c-.8-2.9-2.5-5.4-5.4-6.2C55.8.1 34 0 34 0S12.2.1 6.9 1.6c-2.8.7-4.6 3.2-5.4 6.1C.1 13 0 24 0 24s0 11 1.5 16.3c.8 2.9 2.6 5.4 5.4 6.2C12.2 47.9 34 48 34 48s21.8-.1 27.1-1.6c2.8-.7 4.6-3.2 5.4-6.1C67.9 35 68 24 68 24s0-11-1.5-16.3z" fill="#FF0000"/><path d="M27 34V14l18 10-18 10z" fill="#FFF"/></svg></div>
      </div>
      <div style="margin-top:32px"><a href={site.demo.ctaUrl} class="btn-primary">{site.demo.ctaText}</a></div>
    </div>
  </section>

  <!-- 7. FEATURES -->
  <section class="section-pad section-neutral" id="features">
    <div class="container">
      <h2 class="text-center" style="margin-bottom:48px">Features that remove friction</h2>
      <div class="features-grid">{site.features.map(f => (<div class="feature-tile"><h3>{f.title}</h3><p class="muted">{f.description}</p></div>))}</div>
    </div>
  </section>

  <!-- 8. SECURITY -->
  <section class="section-pad section-dark" id="security">
    <div class="container">
      <h2 class="text-center" style="margin-bottom:12px">How your data is handled</h2>
      <p class="text-center muted" style="margin-bottom:40px;max-width:560px;margin-left:auto;margin-right:auto">Privacy is not a feature. It is how the product works.</p>
      <div class="security-grid">{site.security.points.map(point => (<div class="security-item"><svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 1l7 3v5c0 4.4-3 8.5-7 9.9C6 17.5 3 13.4 3 9V4l7-3z" stroke="#818CF8" stroke-width="1.5" fill="none"/><path d="M7 10l2 2 4-4" stroke="#818CF8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg><p>{point}</p></div>))}</div>
      <div class="text-center" style="margin-top:40px"><a href={site.hero.ctaPrimaryUrl} class="btn-primary">{site.hero.ctaPrimary}</a><span style="margin-left:16px"><a href="/privacy" style="color:var(--dark-accent);font-weight:600">Privacy details</a></span></div>
    </div>
  </section>

  <!-- 9. TESTIMONIALS -->
  <section class="section-pad testimonials-section" id="testimonials">
    <div class="container">
      <h2 class="text-center" style="margin-bottom:40px">What people are saying</h2>
    </div>
    <div class="testimonials-scroll"><div class="testimonials-track">
      {site.testimonials.concat(site.testimonials).map(t => (<div class="testimonial-card"><div class="testimonial-stars">{[1,2,3,4,5].map(() => (<svg width="16" height="16" viewBox="0 0 16 16" fill="#F59E0B"><path d="M8 0l2.5 5 5.5.8-4 3.9.9 5.3L8 12.5 3.1 15l.9-5.3-4-3.9L5.5 5z"/></svg>))}</div><p class="testimonial-quote">"{t.quote}"</p><div class="testimonial-author"><img src={t.headshot} alt={t.name} width="40" height="40" loading="lazy" decoding="async" class="testimonial-avatar" /><div><strong>{t.name}</strong><span class="muted">{t.role}</span></div></div></div>))}
    </div></div>
    <div class="container text-center" style="margin-top:32px"><a href={site.hero.ctaPrimaryUrl} class="btn-primary">{site.hero.ctaPrimary}</a><span style="margin-left:16px"><a href="/contact" style="color:var(--brand);font-weight:600">Contact us</a></span></div>
  </section>

  <!-- 10. PRICING -->
  <section class="section-pad section-neutral" id="pricing">
    <div class="container">
      <h2 class="text-center" style="margin-bottom:12px">Simple, affordable plans</h2>
      <p class="text-center muted" style="margin-bottom:48px">Start free, upgrade when you need more.</p>
      <div class="pricing-grid">
        {site.pricing.tiers.map(tier => (<div class={`pricing-card ${tier.highlighted ? 'pricing-highlighted' : ''}`}>{tier.badge && <span class="pricing-badge">{tier.badge}</span>}<h3>{tier.name}</h3><div class="pricing-price"><span class="pricing-amount">{tier.price}</span>{tier.period && <span class="pricing-period">{tier.period}</span>}</div><p class="muted" style="font-size:14px;margin-bottom:20px">{tier.description}</p><ul class="pricing-features">{tier.features.map(f => (<li><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8l3.5 3.5L13 5" stroke="#4338CA" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>{f}</li>))}</ul><a href={tier.ctaUrl} class={tier.highlighted ? 'btn-primary pricing-cta' : 'btn-secondary pricing-cta'}>{tier.ctaText}</a></div>))}
      </div>
      <p class="text-center muted" style="font-size:13px;margin-top:24px">{site.pricing.disclaimer}</p>
      <p class="text-center" style="margin-top:16px"><a href="/pricing" style="color:var(--brand);font-weight:600">View full feature comparison &rarr;</a></p>
    </div>
  </section>

  <!-- 11. FAQ -->
  <section class="section-pad" id="faq">
    <div class="container" style="max-width:800px">
      <h2 class="text-center" style="margin-bottom:48px">Frequently asked questions</h2>
      {site.faq.map(item => (<details class="faq-item"><summary class="faq-question">{item.question}</summary><div class="faq-answer"><p>{item.answer}</p></div></details>))}
    </div>
  </section>

  <!-- 12. FINAL CTA -->
  <section class="section-pad section-dark" style="padding:60px 0">
    <div class="container text-center">
      <h2 style="margin-bottom:12px">Start dictating today</h2>
      <p class="muted" style="margin-bottom:24px">No credit card. No voice training. Install in 2 minutes.</p>
      <a href={site.hero.ctaPrimaryUrl} class="btn-primary btn-lg">Download free</a>
    </div>
  </section>

  <style is:inline>
    .hero{padding:80px 0 40px;background:#fff}
    .hero-split{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
    .hero-text{text-align:left}
    .hero-eyebrow{font-size:12px;font-weight:600;color:var(--brand);letter-spacing:0.06em;text-transform:uppercase;margin-bottom:12px}
    .hero-headline{font-size:clamp(28px,4vw,46px);font-weight:800;margin-bottom:18px;letter-spacing:-0.03em;line-height:1.15}
    .hero-sub{font-size:15px;color:var(--muted);margin-bottom:24px;line-height:1.7;max-width:520px}
    .hero-bullets{list-style:none;display:flex;flex-direction:column;gap:10px;margin-bottom:28px}
    .hero-bullets li{display:flex;align-items:center;gap:10px;font-size:15px;font-weight:500}
    .hero-ctas{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:10px}
    .btn-lg{padding:14px 36px;font-size:17px}
    .hero-micro{font-size:13px;color:var(--muted)}
    .hero-visual{display:flex;align-items:center;justify-content:center}
    .hero-product{border-radius:16px;overflow:hidden;border:1px solid var(--border);box-shadow:0 16px 48px rgba(0,0,0,0.1);width:100%}
    .hero-product img{width:100%;display:block}
    .hero-product video{width:100%;display:block;aspect-ratio:800/752}
    .clarity-strip{background:var(--dark);padding:20px 0}.clarity-grid{display:flex;justify-content:center;gap:48px;flex-wrap:wrap}.clarity-item{display:flex;gap:8px;align-items:baseline;color:var(--dark-text);font-size:14px}.clarity-label{font-weight:600;color:var(--dark-accent);white-space:nowrap}.clarity-value{color:var(--dark-muted)}
    .stats-section{padding:36px 0}
    .stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;max-width:860px;margin:0 auto}.stat-card{text-align:center;padding:16px 12px}.stat-value{font-size:44px;font-weight:800;display:block;letter-spacing:-0.02em}.stat-label{font-size:14px;color:var(--muted);font-weight:500}
    .founder-layout{display:grid;grid-template-columns:1.2fr 1fr;gap:48px;align-items:start}
    .founder-quote{margin:0;padding:0;border:0}
    .founder-quote p{font-size:18px;line-height:1.7;color:var(--dark-text);font-style:italic;margin-bottom:24px}
    .founder-attribution{display:flex;align-items:center;gap:14px}
    .founder-avatar{width:52px;height:52px;border-radius:50%;background:var(--dark-accent);display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .founder-initials{font-size:20px;font-weight:700;color:#fff}
    .founder-credentials{padding-top:4px}
    .credibility-points{list-style:none;display:flex;flex-direction:column;gap:14px}
    .credibility-points li{display:flex;align-items:flex-start;gap:10px;font-size:14px;line-height:1.6;color:var(--dark-muted)}
    .credibility-points li svg{flex-shrink:0;margin-top:2px}
    .yt-facade{position:relative;max-width:900px;margin:0 auto;cursor:pointer;border-radius:16px;overflow:hidden;background:#000;box-shadow:0 8px 32px rgba(0,0,0,0.12);aspect-ratio:16/9}.yt-facade img{width:100%;height:100%;object-fit:cover}.yt-facade .yt-play{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);opacity:0.9;transition:opacity 0.2s}.yt-facade:hover .yt-play{opacity:1}.yt-facade iframe{position:absolute;top:0;left:0;width:100%;height:100%;border:0}
    .usecase-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
    .usecase-card{background:#fff;border:1px solid var(--border);border-radius:14px;overflow:hidden;transition:border-color 0.2s,box-shadow 0.2s,transform 0.2s;text-decoration:none;color:inherit;display:flex;flex-direction:column}
    .usecase-card:hover{border-color:var(--brand);box-shadow:0 6px 20px rgba(0,0,0,0.06);transform:translateY(-2px)}
    .usecase-card-img{height:140px;overflow:hidden;background:var(--neutral)}
    .usecase-card-img img{width:100%;height:100%;object-fit:cover;object-position:center 20%;transition:transform 0.3s}
    .usecase-card:hover .usecase-card-img img{transform:scale(1.04)}
    .usecase-card-body{padding:20px;flex:1;display:flex;flex-direction:column}
    .usecase-card-body h3{font-size:17px;margin-bottom:8px;font-weight:600}
    .usecase-card-body .muted{font-size:14px;margin-bottom:12px;line-height:1.6}
    .usecase-arrow{font-size:14px;font-weight:600;margin-top:auto}
    .features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}.feature-tile{padding:28px;border:1px solid var(--border);border-radius:14px;background:#fff;transition:box-shadow 0.2s}.feature-tile:hover{box-shadow:0 4px 16px rgba(0,0,0,0.04)}.feature-tile h3{font-size:17px;margin-bottom:8px;font-weight:600}.feature-tile .muted{font-size:14px}
    .testimonials-section{overflow:hidden}
    .testimonials-scroll{overflow:hidden;position:relative;width:100%}
    .testimonials-track{display:flex;gap:20px;width:max-content;animation:scroll-testimonials 40s linear infinite}
    .testimonials-track:hover{animation-play-state:paused}
    @keyframes scroll-testimonials{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
    .testimonial-card{background:#fff;border:1px solid var(--border);border-radius:14px;padding:24px;min-width:300px;max-width:340px;flex-shrink:0}.testimonial-stars{display:flex;gap:2px;margin-bottom:12px}.testimonial-quote{font-size:15px;margin-bottom:16px;line-height:1.6}.testimonial-author{display:flex;align-items:center;gap:10px}.testimonial-avatar{width:40px;height:40px;border-radius:50%;object-fit:cover;background:var(--neutral)}.testimonial-author strong{display:block;font-size:14px}.testimonial-author .muted{font-size:13px}
    .security-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;max-width:720px;margin:0 auto}.security-item{display:flex;gap:12px;align-items:flex-start}.security-item svg{flex-shrink:0;margin-top:2px}.security-item p{font-size:15px}
    .pricing-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;align-items:stretch}.pricing-card{background:#fff;border:1px solid var(--border);border-radius:16px;padding:28px;position:relative;transition:box-shadow 0.2s;display:flex;flex-direction:column}.pricing-card:hover{box-shadow:0 6px 24px rgba(0,0,0,0.06)}.pricing-highlighted{border-color:var(--cta);box-shadow:0 6px 24px rgba(234,88,12,0.1)}.pricing-badge{position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--cta);color:#fff;font-size:12px;font-weight:600;padding:4px 14px;border-radius:20px;white-space:nowrap}.pricing-card h3{font-size:18px;margin-bottom:12px;font-weight:600}.pricing-amount{font-size:36px;font-weight:700;letter-spacing:-0.02em}.pricing-period{font-size:14px;color:var(--muted);margin-left:4px}.pricing-features{list-style:none;margin-bottom:24px;flex:1}.pricing-features li{display:flex;align-items:center;gap:8px;font-size:14px;margin-bottom:8px}.pricing-cta{width:100%;justify-content:center;text-align:center;margin-top:auto}
    .faq-item{border-bottom:1px solid var(--border)}.faq-question{padding:20px 0;font-size:16px;font-weight:600;cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center}.faq-question::-webkit-details-marker{display:none}.faq-question::after{content:'+';font-size:20px;color:var(--muted)}.faq-item[open] .faq-question::after{content:'-'}.faq-answer{padding:0 0 20px}.faq-answer p{color:var(--muted);font-size:15px;line-height:1.7}
    @media(max-width:1024px){.pricing-grid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:768px){.hero-split{grid-template-columns:1fr;gap:32px;text-align:center}.hero-text{text-align:center}.hero-eyebrow{text-align:center}.hero-bullets{align-items:center}.hero-ctas{justify-content:center}.hero-sub{margin-left:auto;margin-right:auto}.stats-grid{grid-template-columns:repeat(2,1fr)}.usecase-grid{grid-template-columns:1fr}.features-grid{grid-template-columns:1fr}.security-grid{grid-template-columns:1fr}.pricing-grid{grid-template-columns:1fr;max-width:400px;margin:0 auto}.clarity-grid{flex-direction:column;gap:12px;align-items:flex-start}.founder-layout{grid-template-columns:1fr}.founder-credentials{margin-top:8px}}
  </style>
  <script is:inline>
    document.querySelectorAll('.yt-facade').forEach(function(el){el.addEventListener('click',function(){var id=el.dataset.ytid;var iframe=document.createElement('iframe');iframe.src='https://www.youtube-nocookie.com/embed/'+id+'?autoplay=1&rel=0&modestbranding=1';iframe.allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture';iframe.allowFullscreen=true;el.innerHTML='';el.appendChild(iframe);});});
  </script>
</BaseLayout>
